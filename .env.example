# ========================================
# Skriptendruck Konfiguration
# ========================================

# Basispfad für die Ordnerstruktur
# Hier liegen die Unterordner:
#   01_Auftraege      – Hier werden neue PDFs abgelegt (File-Watcher überwacht diesen Ordner)
#   02_Druckfertig    – Verarbeitete, druckfertige Aufträge
#   03_Originale      – Kopie der Originaldateien
#   Export/           – Excel-Exporte
#
# Unterstützte Pfadformate:
#   Gemapptes Netzlaufwerk:  H:/stud/fsmb/03_Dienste/01_Skriptendruck
#   UNC-Pfad:                \\\\server\\share\\skriptendruck
#   Lokaler Pfad:            C:/skriptendruck
#
# HINWEIS: In .env Dateien müssen Backslashes verdoppelt werden (\\)
# Beispiel UNC: BASE_PATH=\\\\server\\share\\skriptendruck
# Alternativ Forward-Slashes verwenden: BASE_PATH=//server/share/skriptendruck
BASE_PATH=H:/stud/fsmb/03_Dienste/01_Skriptendruck/test

# LDAP Konfiguration (HS Regensburg Active Directory)
# ------------------
LDAP_ENABLED=true
LDAP_SERVER=adldap.hs-regensburg.de
LDAP_PORT=636
LDAP_USE_SSL=true
LDAP_BASE_DN=dc=hs-regensburg,dc=de
# Bind DN wird aus verschlüsselten Credentials geladen
# Falls hier gesetzt, hat .env Vorrang vor Credentials
LDAP_BIND_DN=
# PASSWORT NICHT HIER EINTRAGEN!
# Stattdessen: poetry run skriptendruck credentials setup
# LDAP_BIND_PASSWORD=

LDAP_SEARCH_FILTER=samAccountName={username}

# Fallback-Dateien
# ----------------
USERS_CSV_PATH=data/users_fallback.csv
BLACKLIST_PATH=data/blacklist.txt

# Preise (in Euro)
# ----------------
PRICE_SW=0.04
PRICE_COLOR=0.10
PRICE_BINDING_SMALL=1.00
PRICE_BINDING_LARGE=1.50
PRICE_FOLDER=0.50

# Seitengrenzen
# -------------
MIN_PAGES=1
MAX_PAGES_SMALL_BINDING=300
MAX_PAGES_LARGE_BINDING=660

# Bindungsgrößen
# --------------
BINDING_SIZES_PATH=data/binding_sizes.json

# Excel Export
# Eigener Pfad für Abrechnungs- und Auftragslisten
EXCEL_EXPORT_PATH=H:/stud/fsmb/03_Dienste/01_Skriptendruck/Export

# Datenbank
# ---------
DATABASE_PATH=skriptendruck.db
USE_DATABASE=true

# Performance
# -----------
PARALLEL_PROCESSING=true
MAX_WORKERS=4

# Logging
# -------
LOG_LEVEL=INFO
# Optional: Log-Datei aktivieren
#LOG_FILE=skriptendruck.log

# Drucker
PRINTER_SW=Microsoft Print to PDF
PRINTER_COLOR=Microsoft Print to PDF
SUMATRA_PDF_PATH=C:/Program Files/SumatraPDF/SumatraPDF.exe
AUTO_PRINT=false

# ========================================
# Web-Dashboard Konfiguration
# ========================================
# Admin-Fallback (wenn LDAP nicht verfügbar)
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=changeme

# Server-Einstellungen
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# Session Secret (wird automatisch generiert wenn nicht gesetzt)
# DASHBOARD_SECRET_KEY=your-random-secret-key-here

# ========================================
# File-Watcher Konfiguration
# ========================================
# Automatische Erkennung neuer PDFs im Auftragsordner.
# Der File-Watcher überwacht standardmäßig: {BASE_PATH}/01_Auftraege
FILE_WATCHER_ENABLED=true

# Scan-Intervall in Sekunden (wie oft wird der Ordner geprüft)
FILE_WATCHER_INTERVAL=10

# Optionaler Pfad zum Auftragsordner (Standard: BASE_PATH/01_Auftraege)
# Nur setzen, wenn der Auftragsordner NICHT unter BASE_PATH/01_Auftraege liegt.
# Unterstützt die gleichen Pfadformate wie BASE_PATH (lokal, Netzlaufwerk, UNC).
# FILE_WATCHER_DIR=
# FILE_WATCHER_DIR=Z:\\skriptendruck\\01_Auftraege
# FILE_WATCHER_DIR=\\\\server\\share\\skriptendruck\\01_Auftraege